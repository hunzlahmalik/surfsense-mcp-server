SURFSENSE_BASE_URL=https://foss-research.local.moneta.dev

# --- Primary auth (stdio): paste a fresh JWT from the SurfSense web UI. ---
# When this expires, paste a new one. The server does not refresh it.
SURFSENSE_JWT=

# --- Optional stdio fallback: email + password auto-login. ---
# If SURFSENSE_JWT is empty and both of these are set, the server will call
# POST /auth/jwt/login, cache the token for TOKEN_TTL seconds, and transparently
# retry once on 401. Intended for CI / long-running stdio sessions.
# HTTP mode ignores these — it only honours Authorization: Bearer headers.
SURFSENSE_EMAIL=
SURFSENSE_PASSWORD=

# Cached-token lifetime for the password-login fallback (seconds, min 60).
# Default is 3300 (55 min), below fastapi-users' typical 60-min JWT expiry.
TOKEN_TTL=3300
